<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvRemoveTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Found Apple AirPods"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:id="@+id/imgRemovePreview"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="18dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:contentDescription="Lost and found item image" />

        <TextView
            android:id="@+id/tvRemoveDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 days ago"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/tvRemoveLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="At Burwood campus"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="18dp" />

        <TextView
            android:id="@+id/tvRemoveCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Category: Electronics"
            android:textSize="16sp"
            android:layout_marginBottom="40dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnRemoveItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REMOVE" />

    </LinearLayout>

</ScrollView>